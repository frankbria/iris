# IRIS environment variables — reference list of what the CLI reads.
# Copy to .env (`cp .env.example .env`) and fill in the ones you need; the CLI
# auto-loads .env at startup. Shell-exported variables take precedence over .env.
# Do NOT commit real credentials (.env is gitignored).

# AI provider credentials (set the one matching your provider)
OPENAI_API_KEY=sk-...                     # OpenAI GPT-4o vision/text
ANTHROPIC_API_KEY=sk-ant-...              # Anthropic Claude vision/text
OLLAMA_ENDPOINT=http://localhost:11434    # Local Ollama endpoint (no key needed)
OLLAMA_MODEL=llama2                        # Ollama model name

# Optional: override the SQLite database path (default: ~/.iris/iris.db)
IRIS_DB_PATH=~/.iris/iris.db

# Optional: origin for relative --pages patterns in visual-diff and a11y runs.
# Absolute URLs in --pages always pass through unchanged. The --base-url flag
# overrides this. Default when unset: http://localhost:3000
IRIS_BASE_URL=http://localhost:3000
