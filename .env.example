# IRIS environment variables — reference list of what the CLI reads.
# Export the ones you need in your shell (the CLI does not auto-load a .env file).
# Do NOT commit real credentials.

# AI provider credentials (set the one matching your provider)
OPENAI_API_KEY=sk-...                     # OpenAI GPT-4o vision/text
ANTHROPIC_API_KEY=sk-ant-...              # Anthropic Claude vision/text
OLLAMA_ENDPOINT=http://localhost:11434    # Local Ollama endpoint (no key needed)
OLLAMA_MODEL=llama2                        # Ollama model name

# Optional: override the SQLite database path (default: ~/.iris/iris.db)
IRIS_DB_PATH=~/.iris/iris.db
